# Копируйте в .deploy.env и заполните
SSHPASS=
VPS_HOST=192.210.213.135
VPS_USER=root

# AI — обязательно для чата и картинок (enter.pollinations.ai)
POLLINATIONS_API_KEY=sk_your_key_here

# ChatGPT — прямой ключ OpenAI (platform.openai.com)
OPENAI_API_KEY=sk-proj-your_key_here

# Perplexity — бесплатный тариф (perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_key_here

# Опционально — OpenRouter (openrouter.ai)
OPENROUTER_API_KEY=

# Опционально — прямой Google Gemini (aistudio.google.com)
GEMINI_API_KEY=AIza_your_key_here

# Афиша и VK
KINOPOISK_API_TOKEN=
VK_GROUP_TOKEN=
VK_CONFIRMATION_CODE=
VK_SECRET_KEY=
VK_GROUP_ID=
VK_GROUP_URL=
# 0 = не спамить стену каждым событием (рекомендуется)
VK_WALL_POST_ENABLED=0
