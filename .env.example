# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=narodny_kontrol

# Backend
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=false
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# Super Admin (created on first seed)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-me-admin-password

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# Опционально — Pollinations gen API (если понадобится ключ)
POLLINATIONS_API_KEY=

# VKontakte
VK_GROUP_TOKEN=your-vk-group-token
VK_CONFIRMATION_CODE=your-confirmation-code
VK_SECRET_KEY=your-secret-key
# Ссылка на сообщество ВК — жители пишут боту в личные сообщения группы
# Пример: https://vk.com/im?sel=-123456789  или  https://vk.com/club123456789
VK_GROUP_URL=https://vk.com/im?sel=-YOUR_GROUP_ID
PUBLIC_SITE_URL=https://pushkinskie-gory.ru
VK_ADMIN_PEER_ID=your-vk-user-id-for-notifications

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# Rate limiting
RATE_LIMIT=100/minute

# Duplicate detection threshold (0.0 - 1.0)
DUPLICATE_THRESHOLD=0.80

# Public AI chat limits (messages per day)
AI_FREE_DAILY_LIMIT=30
AI_VK_DAILY_LIMIT=20

# Payment / support (card transfer for extended AI usage)
PAYMENT_CARD_NUMBER=2204240170359972
PAYMENT_CARD_HOLDER=Портал ПГ
PAYMENT_BANK_NAME=Сбербанк
PAYMENT_DESCRIPTION=Поддержка ИИ Пушкинские Горы
PAYMENT_AMOUNT_SUGGESTED=150
CLASSIFIED_FREE_LIMIT=3
CLASSIFIED_PLACEMENT_FEE=150
CLASSIFIED_PAYMENT_DESCRIPTION=Объявление Пушкинские Горы
PAYMENT_CONTACT_EMAIL=your@email.com
